<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="InternalsViewer.UI.App.Controls.Docking.TabGroupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="RootArea"
          Background="Transparent"
          AllowDrop="True"
          DragOver="OnDropOver"
          DragLeave="OnDropLeave"
          Drop="OnDrop">
        <TabView x:Name="Tabs"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 CanDragTabs="True"
                 CanReorderTabs="True"
                 IsAddTabButtonVisible="False"
                 TabWidthMode="SizeToContent"
                 Loaded="OnTabsLoaded"
                 SelectionChanged="OnSelectionChanged"
                 TabDragStarting="OnTabDragStarting"
                 TabDragCompleted="OnTabDragCompleted"
                 TabCloseRequested="OnTabCloseRequested"/>

        <!-- Landing-zone indicator drawn over the content while a tab is dragged here. -->
        <Border x:Name="DropHighlight"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                BorderThickness="2"
                Opacity="0.5"/>
    </Grid>
</UserControl>
