<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="InternalsViewer.UI.App.Controls.QueryReplay.EventFilterControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:queryReplay="using:InternalsViewer.UI.App.ViewModels.Query"
    x:Name="Root"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <CheckBox Grid.Row="0"
                  Margin="8,6,8,2"
                  Content="Include System Objects"
                  IsChecked="{x:Bind ViewModel.IncludeSystemObjects, Mode=TwoWay}"/>

        <TreeView Grid.Row="1"
                  SelectionMode="None"
                  ItemsSource="{x:Bind ViewModel.FilterNodes, Mode=OneWay}">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="Padding" Value="0,1,0,1"/>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="queryReplay:EventFilterNode">
                    <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}"
                                  IsExpanded="True"
                                  MinHeight="0"
                                  Padding="0,1,0,1">
                        <CheckBox Content="{x:Bind Label, Mode=OneWay}"
                                  IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                  IsThreeState="{x:Bind IsLeaf, Converter={StaticResource BoolNegationConverter}, Mode=OneWay}"
                                  MinHeight="0"
                                  Padding="4,2"
                                  MinWidth="0"
                                  FontSize="{ThemeResource ControlContentThemeFontSize}"/>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
