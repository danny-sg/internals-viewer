<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="InternalsViewer.UI.App.Controls.QueryReplay.EventGridControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:events="using:InternalsViewer.Replay.Events"
    xmlns:eventTypes="using:InternalsViewer.Replay.Events.EventTypes"
    x:Name="Root"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <AutoSuggestBox x:Name="SearchBox"
                        Grid.Row="0"
                        Margin="0,0,0,4"
                        PlaceholderText="Search all fields..."
                        QueryIcon="Find"
                        TextChanged="OnSearchTextChanged"/>

        <toolkit:DataGrid x:Name="DataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          GridLinesVisibility="Vertical"
                          Background="{ThemeResource LayerFillColorDefaultBrush}">
            <toolkit:DataGrid.Columns>

                <toolkit:DataGridTemplateColumn Header="Event" Tag="Event">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="eventTypes:EngineEvent">
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <toolkit:DataGridTemplateColumn Header="Type" Tag="Type">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="eventTypes:EngineEvent">
                            <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <toolkit:DataGridTemplateColumn Header="Time (ms)" Tag="TimeMs">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="eventTypes:EngineEvent">
                            <TextBlock Text="{x:Bind TimeMs, Mode=OneWay}"
                                       Margin="4,0,10,0"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <toolkit:DataGridTemplateColumn Header="Duration (ms)" Tag="Duration">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="eventTypes:EngineEvent">
                            <TextBlock Text="{x:Bind Duration, Mode=OneWay}"
                                       Margin="4,0,10,0"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <toolkit:DataGridTemplateColumn Header="Page" Tag="PageAddress">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="eventTypes:EngineEvent">
                            <Grid>
                                <HyperlinkButton Content="{x:Bind PageAddress, Mode=OneWay}"
                                                 Style="{StaticResource PageAddressStyle}"
                                                 Tag="{x:Bind PageAddress}"
                                                 Click="HyperlinkButton_Click"/>
                            </Grid>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <toolkit:DataGridTemplateColumn Header="Object" Tag="Object">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="eventTypes:EngineEvent">
                            <TextBlock Text="{x:Bind ObjectName, Mode=OneWay}"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <toolkit:DataGridTemplateColumn Header="Sequence Id" Tag="SequenceId">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="eventTypes:EngineEvent">
                            <TextBlock Text="{x:Bind SequenceId, Mode=OneWay}"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>


                <toolkit:DataGridTemplateColumn Header="Node Id" Tag="NodeId">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="eventTypes:EngineEvent">
                            <TextBlock Text="{x:Bind PlanNodeIdentifier, Mode=OneWay}"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>
            </toolkit:DataGrid.Columns>
        </toolkit:DataGrid>
    </Grid>
</UserControl>
