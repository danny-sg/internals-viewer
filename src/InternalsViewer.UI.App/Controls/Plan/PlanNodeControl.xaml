<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="InternalsViewer.UI.App.Controls.Plan.PlanNodeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternalsViewer.UI.App.Controls.Plan"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border x:Name="NodeBorder"
            BorderThickness="0"
            Padding="0,4,0,0"
            CornerRadius="4"
            ToolTipService.ToolTip="{x:Bind ToolTipText, Mode=OneWay}">
        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Center"
                    Spacing="2">
            <Image Source="{x:Bind IconSource, Mode=OneWay}"
                   Width="32"
                   Height="32"
                   HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind OperatorName, Mode=OneWay}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind DetailText, Mode=OneWay}"
                       FontSize="10"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind DetailVisibility, Mode=OneWay}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind CostText, Mode=OneWay}"
                       FontSize="10"
                       TextAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind CostVisibility, Mode=OneWay}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
