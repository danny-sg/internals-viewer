<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="InternalsViewer.UI.App.Controls.Query.SqlDocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sqlEditor="using:InternalsViewer.UI.App.Controls.SqlEditor"
    mc:Ignorable="d">
    <sqlEditor:SqlEditorControl x:Name="SqlEditor"
                                IsExecuting="{x:Bind ViewModel.ExecuteQueryCommand.IsRunning, Mode=OneWay}"
                                ExecuteCommand="{x:Bind ViewModel.ExecuteQueryCommand, Mode=OneWay}"
                                Message="{x:Bind ViewModel.Message, Mode=OneWay}"
                                IsError="{x:Bind ViewModel.IsError, Mode=OneWay}"
                                Theme="vs-light" />
</UserControl>
