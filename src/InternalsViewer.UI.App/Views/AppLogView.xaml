<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="InternalsViewer.UI.App.Views.AppLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:logging="using:InternalsViewer.Internals.Services.Logging"
    xmlns:converters="using:InternalsViewer.UI.App.Helpers.Converters"
    xmlns:logControls="using:InternalsViewer.UI.App.Controls.Logging"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="8,4" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Log level" VerticalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{x:Bind ViewModel.LogLevels}"
                      SelectedItem="{x:Bind ViewModel.SelectedLogLevel, Mode=TwoWay}"
                      MinWidth="120"/>
            <TextBlock Grid.Column="2" Text="Max messages" VerticalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}" Margin="16,0,6,0"/>
            <NumberBox Grid.Column="3"
                       Value="{x:Bind ViewModel.MaxLogEntries, Mode=TwoWay}"
                       Minimum="100" Maximum="10000"
                       SmallChange="100" LargeChange="500"
                       SpinButtonPlacementMode="Compact"
                       MinWidth="100"/>
            <Button Grid.Column="7"
                    Command="{x:Bind ViewModel.ClearLogCommand}"
                    Content="Clear"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="Padding" Value="4,1"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="logging:LogEntry">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind TimestampText}"
                                   Foreground="{x:Bind Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                   IsTextSelectionEnabled="True"
                                   FontFamily="Consolas"
                                   FontSize="11"/>
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Level}"
                                   Foreground="{x:Bind Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                   IsTextSelectionEnabled="True"
                                   FontFamily="Consolas"
                                   FontSize="11"/>
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind ShortCategory}"
                                   Foreground="{x:Bind Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                   IsTextSelectionEnabled="True"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                        <logControls:LogMessageControl Grid.Column="3" Entry="{x:Bind}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
