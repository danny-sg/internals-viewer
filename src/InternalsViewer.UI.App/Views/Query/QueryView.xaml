<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="InternalsViewer.UI.App.Views.QueryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternalsViewer.UI.App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:timeline="using:InternalsViewer.UI.App.Controls.Timeline"
    xmlns:queryReplay="using:InternalsViewer.UI.App.Controls.QueryReplay"
    xmlns:docking="using:InternalsViewer.UI.App.Controls.Docking"
    mc:Ignorable="d">

    <SplitView x:Name="EventSelectionPanel"
               DisplayMode="Overlay"
               PanePlacement="Right"
               OpenPaneLength="320"
               IsPaneOpen="{x:Bind ViewModel.IsEventSelectionPanelOpen, Mode=TwoWay}">
        <SplitView.Pane>
            <Grid Padding="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Query Settings"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,8"/>
                <CheckBox Grid.Row="1" IsChecked="{x:Bind ViewModel.CropToQuery, Mode=TwoWay}">Crop</CheckBox>
                <queryReplay:EventFilterControl Grid.Row="2"
                                               ViewModel="{x:Bind ViewModel.EventFilter, Mode=OneWay}"/>
            </Grid>
        </SplitView.Pane>
        <SplitView.Content>
            <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{x:Bind ViewModel.TimelineRowHeight, Mode=OneWay}"/>
                </Grid.RowDefinitions>

                <!-- Menu/Command Bar -->
                <Border        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                               BorderThickness="0,0,0,1">
                <CommandBar DefaultLabelPosition="Right">
                    <CommandBar.Content>
                        <MenuBar Grid.Row="0"
                                 Height="48"
                                 Padding="0">
                            <MenuBar.Resources>
                                <x:Double x:Key="ControlContentThemeFontSize">12</x:Double>
                        
                            </MenuBar.Resources>
                            <MenuBarItem Title="View">
                                <ToggleMenuFlyoutItem Text="SQL Editor"
                                                      IsChecked="{x:Bind ViewModel.IsSqlEditorVisible, Mode=TwoWay}"/>
                                <ToggleMenuFlyoutItem Text="Allocations"
                                                      IsChecked="{x:Bind ViewModel.IsAllocationsVisible, Mode=TwoWay}"/>
                                <ToggleMenuFlyoutItem Text="Execution Plan"
                                                      IsChecked="{x:Bind ViewModel.IsExecutionPlanVisible, Mode=TwoWay}"/>
                                <ToggleMenuFlyoutItem Text="Events"
                                                      IsChecked="{x:Bind ViewModel.IsEventsVisible, Mode=TwoWay}"/>
                                <MenuFlyoutSeparator/>
                                <ToggleMenuFlyoutItem Text="Timeline"
                                                      IsChecked="{x:Bind ViewModel.IsTimelineVisible, Mode=TwoWay}"/>
                                <ToggleMenuFlyoutItem Text="Settings"
                                                      IsChecked="{x:Bind ViewModel.IsEventSelectionPanelOpen, Mode=TwoWay}"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Reset Layout"
                                                Command="{x:Bind ViewModel.ResetLayoutCommand}"/>
                            </MenuBarItem>

                            <!--<MenuBarItem Title="Help">
                                <MenuFlyoutItem Text="About"/>
                            </MenuBarItem>-->
                        </MenuBar>
                    </CommandBar.Content>

                    <CommandBar.PrimaryCommands>
                        <AppBarElementContainer>
                            <StackPanel Orientation="Horizontal"
                                        Height="40"
                                        VerticalAlignment="Center"
                                        Spacing="8"
                                        Margin="12,0,0,0"
                                        Visibility="{x:Bind ViewModel.ActiveOperatorVisibility, Mode=OneWay}">
                                <Image Source="{x:Bind ViewModel.ActiveOperatorIcon, Mode=OneWay}"
                                       Width="18"
                                       Height="18"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.ActiveOperatorName, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ViewModel.ActiveOperatorObject, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </AppBarElementContainer>
                        <AppBarToggleButton Label="SQL Editor"
                                            IsChecked="{x:Bind ViewModel.IsSqlEditorVisible, Mode=TwoWay}">
                            <AppBarToggleButton.Icon>
                                <FontIcon Glyph="&#xE943;"/>
                            </AppBarToggleButton.Icon>
                        </AppBarToggleButton>
                        <AppBarToggleButton Label="Timeline"
                                            IsChecked="{x:Bind ViewModel.IsTimelineVisible, Mode=TwoWay}">
                            <AppBarToggleButton.Icon>
                                <FontIcon Glyph="&#xEC92;"/>
                            </AppBarToggleButton.Icon>
                        </AppBarToggleButton>
                    </CommandBar.PrimaryCommands>

                </CommandBar>
                </Border>
                <!--Tabs (dockable / splittable document region)-->
                <docking:DockHost x:Name="DockHostControl"
                                  Grid.Row="1"
                           
                                  Layout="{x:Bind ViewModel.Dock, Mode=OneWay}"/>

                <!--Timeline splitter-->
                <controls:GridSplitter Grid.Row="2"
                               Height="2"
                               Visibility="{x:Bind ViewModel.TimelineSplitterVisibility, Mode=OneWay}"
                               Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                               VerticalAlignment="Stretch">
                    <controls:GridSplitter.Template>
                        <ControlTemplate TargetType="controls:GridSplitter">
                            <Grid Background="{TemplateBinding Background}" />
                        </ControlTemplate>
                    </controls:GridSplitter.Template>
                </controls:GridSplitter>

                <!--Timeline-->
                <timeline:EventTimelineControl Grid.Row="3"
                                               x:Name="EventTimeline"
                                               VerticalAlignment="Stretch"
                                               HorizontalAlignment="Stretch"
                                               StartTime="{x:Bind ViewModel.StartTime, Mode=OneWay}"
                                               EndTime="{x:Bind ViewModel.EndTime, Mode=OneWay}"
                                               Events="{x:Bind ViewModel.FilteredEvents, Mode=OneWay}" />
            </Grid>
        </SplitView.Content>
    </SplitView>
</Page>
