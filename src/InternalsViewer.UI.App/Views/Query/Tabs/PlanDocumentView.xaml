<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="InternalsViewer.UI.App.Views.Query.Tabs.PlanDocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:plan="using:InternalsViewer.UI.App.Controls.Plan"
    xmlns:plans="using:InternalsViewer.Query.Plans"
    mc:Ignorable="d">
    <UserControl.Resources>
        <StackLayout Orientation="Vertical" Spacing="24" x:Key="PlanStackLayout" />
        <DataTemplate x:Key="ExecutionPlanTemplate" x:DataType="plans:ExecutionPlan">
            <plan:ExecutionPlanControl Plan="{x:Bind}" />
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Enabled"
                  VerticalScrollMode="Enabled"
                  ZoomMode="Enabled"
                  MinZoomFactor="0.25"
                  MaxZoomFactor="2.0"
                  Background="White"
                  Padding="8">
        <ItemsRepeater x:Name="PlanRepeater"
                       ItemsSource="{x:Bind ViewModel.ExecutionPlans, Mode=OneWay}"
                       Layout="{StaticResource PlanStackLayout}"
                       ItemTemplate="{StaticResource ExecutionPlanTemplate}" />
    </ScrollViewer>
</UserControl>
