<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="InternalsViewer.UI.App.Views.QueryReplayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternalsViewer.UI.App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sqlEditor="using:InternalsViewer.UI.App.Controls.SqlEditor"
    xmlns:allocation="using:InternalsViewer.UI.App.Controls.Allocation"
    xmlns:models="using:InternalsViewer.UI.App.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:timeline="using:InternalsViewer.UI.App.Controls.Timeline"
    xmlns:queryReplay="using:InternalsViewer.UI.App.Controls.QueryReplay"
    mc:Ignorable="d">
    <UserControl.Resources>
        <StackLayout Orientation="Vertical" x:Key="VerticalStackLayout" />
        <DataTemplate x:Key="AllocationFileTemplate" x:DataType="models:DatabaseFile">
            <Grid>
                <allocation:AllocationControl IsTooltipEnabled="{x:Bind Parent.IsTooltipEnabled, Mode=OneWay}"
                                              Height="{x:Bind Parent.AllocationMapHeight, Mode=OneWay}"
                                              Size="{x:Bind Parent.ExtentCount, Mode=OneWay}" 
                                              Layers="{x:Bind Parent.AllocationLayers, Mode=OneWay}"
                                              SelectedLayers="{x:Bind Parent.SelectedLayers, Mode=OneWay}"
                                              FileId="{x:Bind FileId, Mode=OneWay}"
                                              BorderColor="{ThemeResource CardStrokeColorDefault}"
                                              GridColor="{ThemeResource AllocationBorderColor}"
                                              PfsChain="{x:Bind Parent.PfsChain, Mode=OneWay}"
                                              IsPfsVisible="{x:Bind Parent.IsPfsVisible, Mode=OneWay}"
                                              SequenceFrom="{x:Bind Parent.SequenceFrom, Mode=OneWay}"
                                              SequenceTo="{x:Bind Parent.SequenceTo, Mode=OneWay}"
                                              PageClicked="OnPageSelected"
                                              x:Name="AllocationControl"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <CommandBar IsOpen="False" 
                    DefaultLabelPosition="Right"
                    Grid.Row="0"
                    HorizontalAlignment="Left"
                    Background="Transparent">
            <AppBarToggleButton Label="Locks" 
                                IsChecked="{x:Bind ViewModel.IncludeLocks, Mode=TwoWay}" />
            <AppBarToggleButton Label="I/O" 
                                IsChecked="{x:Bind ViewModel.IncludeIo, Mode=TwoWay}" />
        </CommandBar>
        <ItemsRepeater
            x:Name="AllocationItemRepeater"
            Grid.Row="1" 
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ItemsSource="{x:Bind ViewModel.DatabaseFiles}"
            Layout="{StaticResource VerticalStackLayout}"
            ItemTemplate="{StaticResource AllocationFileTemplate}" />

        <controls:GridSplitter Grid.Row="2"
                              Grid.ColumnSpan="1"
                              Height="16"
                              VerticalAlignment="Top">
            <controls:GridSplitter.RenderTransform>
                <TranslateTransform Y="-7" />
            </controls:GridSplitter.RenderTransform>
        </controls:GridSplitter>
        <Grid Background="{ThemeResource LayerFillColorDefaultBrush}" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" x:Name="EditorColumn"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" x:Name="EventColumn"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <CommandBar IsOpen="False" 
                                DefaultLabelPosition="Right"
                                Grid.Row="0"
                                HorizontalAlignment="Left"
                                Background="Transparent">
                        <AppBarButton Label="Execute" Icon="Play"
                                      Command="{x:Bind ViewModel.ExecuteQueryCommand}" />
                        <AppBarToggleButton Label="Clear Buffer Pool" 
                                            IsChecked="{x:Bind ViewModel.IsClearBufferPool, Mode=TwoWay}" />
                    </CommandBar>
                    <sqlEditor:SqlEditorControl Grid.Row="1"
                                            x:Name="SqlEditor"
                                            SqlText="{x:Bind ViewModel.Sql, Mode=OneWay}"
                                            SqlTextChanged="OnSqlTextChanged"
                                            Theme="vs-light" />
                </Grid>

                <controls:GridSplitter Grid.Column="1"
                                       Width="16"
                                       HorizontalAlignment="Center"
                                       Visibility="{x:Bind ViewModel.HasEvents, Mode=OneWay}">
                    <controls:GridSplitter.RenderTransform>
                        <TranslateTransform X="-7" />
                    </controls:GridSplitter.RenderTransform>
                </controls:GridSplitter>

                <!-- Right panel: Events grid + filter tree in tabs -->
                <TabView Grid.Column="2"
                         IsAddTabButtonVisible="False"
                         VerticalAlignment="Stretch"
                         TabWidthMode="SizeToContent">
                    <TabViewItem Header="Messages" IsClosable="False">
                        <Border Background="White" Padding="8" VerticalAlignment="Stretch">

                            <TextBlock x:Name="ResultMessage"
                                   Text="{x:Bind ViewModel.Message, Mode=OneWay}"      
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top"
                                   FontFamily="Courier New"
                                   Foreground="{x:Bind ViewModel.ResultBrush, Mode=OneWay}" />
                        </Border>
                    </TabViewItem>
                    <TabViewItem Header="Events" IsClosable="False">
                        <queryReplay:EventGridControl x:Name="EventGrid"
                                                      Events="{x:Bind ViewModel.FilteredEvents, Mode=OneWay}"
                                                      SequenceFrom="{x:Bind ViewModel.SequenceFrom, Mode=OneWay}"
                                                      SequenceTo="{x:Bind ViewModel.SequenceTo, Mode=OneWay}"
                                                      PageClicked="OnPageSelected"/>
                    </TabViewItem>

                    <TabViewItem Header="Event Selection" IsClosable="False">
                        <queryReplay:EventFilterControl FilterNodes="{x:Bind ViewModel.FilterNodes, Mode=OneWay}"
                                                        IncludeSystemObjects="{x:Bind ViewModel.IncludeSystemObjects, Mode=TwoWay}"/>
                    </TabViewItem>

                </TabView>

            </Grid>

            <timeline:EventTimelineControl Grid.Row="2"
                                           x:Name="EventTimeline"
                                           Events="{x:Bind ViewModel.FilteredEvents, Mode=OneWay}"
                                           Height="50"/>
        </Grid>
    </Grid>
</Page>
