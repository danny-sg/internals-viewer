<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="InternalsViewer.UI.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">
    <StackPanel Padding="20" Spacing="12">

        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}">Settings</TextBlock>

        <controls:SettingsCard x:Name="AboutSettingsCard"
                               Description="Internals Viewer"
                               Header="About">
            <StackPanel HorizontalAlignment="Right">
                <TextBlock>Created by Danny Gould</TextBlock>
                <TextBlock>Copyright © 2007 - 2026</TextBlock>
                <HyperlinkButton NavigateUri="https://github.com/danny-sg/internals-viewer">
                    https://github.com/danny-sg/internals-viewer
                </HyperlinkButton>
            </StackPanel>
        </controls:SettingsCard>

        <controls:SettingsCard Header="Diagnostic Log"
                               Description="Activity log from the internals loading pipeline">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="ClearLogButton" Content="Clear Log" Click="ClearLogButton_Click"/>
                <Button x:Name="OpenLogButton" Content="Open Log" Click="OpenLogButton_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
        </controls:SettingsCard>

    </StackPanel>
</Page>